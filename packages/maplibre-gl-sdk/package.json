{
  "name": "@mapka/maplibre-gl-sdk",
  "version": "0.16.2",
  "type": "module",
  "description": "Mapka JS SDK",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mapka-dev/sdk.git"
  },
  "exports": {
    ".": "./lib/index.js",
    "./styles.css": "./lib/styles.css"
  },
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "styles": "lightningcss --minify --bundle ./src/styles.css -o lib/styles.css",
    "styles:watch": "nodemon --watch src --ext css --exec yarn styles"
  },
  "keywords": [
    "map",
    "maplibre",
    "mapka",
    "sdk"
  ],
  "author": "chyzwar",
  "license": "Apache-2.0",
  "dependencies": {
    "es-toolkit": "^1.45.1",
    "html-to-image": "^1.11.13",
    "maplibre-gl": "^5.22.0",
    "preact": "^10.29.1",
    "supercluster": "^8.0.1",
    "terra-draw": "^1.28.1",
    "terra-draw-maplibre-gl-adapter": "^1.3.0"
  },
  "devDependencies": {
    "@chyzwar/tsconfig": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "happy-dom": "^20.8.9",
    "lightningcss": "^1.32.0",
    "lightningcss-cli": "^1.32.0",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "files": [
    "src/",
    "lib/",
    "!**/__tests__/",
    "!lib/buildInfo.json"
  ]
}
